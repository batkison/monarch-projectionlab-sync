{
  "manifest_version": 3,
  "name": "Monarch → ProjectionLab Sync",
  "version": "1.3.1",
  "description": "Sync account balances from Monarch Money into ProjectionLab with one click.",

  "permissions": ["storage", "scripting", "tabs"],

  "host_permissions": [
    "https://app.monarch.com/*",
    "https://api.monarch.com/*",
    "https://app.projectionlab.com/*",
    "https://ea.projectionlab.com/*"
  ],

  "options_page": "options.html",

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": { "service_worker": "src/background.js" },

  "content_scripts": [
    {
      "matches": ["https://app.projectionlab.com/*", "https://ea.projectionlab.com/*"],
      "js": ["src/pl-bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://app.monarch.com/*"],
      "js": ["src/monarch-bridge.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["src/pl-page.js"],
      "matches": ["https://app.projectionlab.com/*", "https://ea.projectionlab.com/*"]
    },
    {
      "resources": ["src/monarch-page.js"],
      "matches": ["https://app.monarch.com/*"]
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
